# Copy to `.env` (gitignored) — read by docker-compose.yml.
#
# The operator panel is the PRIVILEGED write path; it refuses to start without a
# token (§18.3 localhost+token). Generate a strong one, e.g. `openssl rand -hex 32`.
AETHER_OPERATOR_TOKEN=change-me

# --- cross-machine (optional) ----------------------------------------------
# Redis password. EMPTY = auth OFF (localhost dev byte-identical). Set a strong
# value to require AUTH on the bus (then every client/Observatory needs it too,
# via AETHER_REDIS_PASSWORD in its env — NOT in the ~/.aether profile).
AETHER_REDIS_PASSWORD=

# TLS to the bus (client side). Server TLS auto-enables when aether/certs exists
# (run aether/scripts/make-certs.sh). Clients set:
#   AETHER_REDIS_TLS=1
#   AETHER_REDIS_TLS_CA=/abs/path/to/ca.crt
AETHER_REDIS_TLS=
AETHER_REDIS_TLS_CA=
